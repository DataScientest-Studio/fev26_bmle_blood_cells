# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# Chemins dataset
DATA_RAW_DIR=data/raw
DATA_INTERIM_DIR=data/interim

# Chemins modèles
MODELS_DIR=models

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001

# Streamlit
STREAMLIT_MODEL_DIR=models/densenet121_crossval_v1

# DagsHub — modèle DenseNet + images de test
# Token : dagshub.com > Settings > Tokens > Default Access Token (bouton Copy)
DAGSHUB_REPO_OWNER=Dumegan
DAGSHUB_USER=your_dagshub_username_here
DAGSHUB_TOKEN=your_dagshub_token_here
DAGSHUB_REPO=Bloodcells-project

# GitHub — uniquement pour le push automatique de models.dvc par le pipeline
# Airflow après promotion @production (sync_to_datalake). Token fine-grained,
# scope "Contents: Read and write" sur CE repo uniquement :
# github.com > Settings > Developer settings > Fine-grained tokens
GITHUB_TOKEN=your_github_token_here

# URL FastAPI — localhost en dev local, http://api:8000 en Docker Compose
API_URL=http://localhost:8000

# API Key — partagée entre Streamlit et FastAPI (service-to-service)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Doit être identique dans les deux services du docker-compose
API_SECRET_KEY=your_api_secret_key_here

# Supabase (PostgreSQL) — pooler session mode (IPv4, fonctionne partout : Docker, Windows, réseaux sans IPv6)
# Credentials à récupérer auprès de l'équipe
SUPABASE_HOST=aws-0-eu-west-1.pooler.supabase.com
SUPABASE_PORT=6543
SUPABASE_DB=postgres
SUPABASE_USER=postgres.ckwlujqjmlvnnbsijxjw
SUPABASE_PASSWORD=your_supabase_password_here

# Supabase SDK REST (pour _log_to_supabase / supabase Python client)
# Récupérer dans : Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://ckwlujqjmlvnnbsijxjw.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Airflow — entraînement distant sur PC Windows (GPU) via SSH/Tailscale
# Propres à TA topologie réseau : ne jamais committer de vraie valeur
# MAC_TAILSCALE_IP=100.x.x.x
# WINDOWS_TAILSCALE_IP=100.x.x.x
# WINDOWS_SSH_USER=ton_user_windows
# WINDOWS_REPO_DIR=C:\Users\toi\source\repos\fev26_bmle_blood_cells
# AIRFLOW_ADMIN_PASSWORD=mot_de_passe_admin_airflow (utilisé par generate_guide_connexion_tailscale.py)

# Chemins personnels — uniquement nécessaires pour certains scripts de recherche
# (scripts/find_best_tiffs.py, validate_on_cancer_archive.py, compare_1fold_vs_5fold.py,
#  src/train/train_simple.py, src/evaluation/eval_experiments.py, eval_best_models.py).
# Propres à TA machine : ne jamais committer de vraie valeur, laisser commenté si inutilisé.
# CROSSVAL_CACHE_DIR=/chemin/vers/ton/cache/DL_crossval_ameliorees
# CANCER_ARCHIVE_DIR=/chemin/vers/CancerImagingArchive
# ONEDRIVE_CACHE_DIR=/chemin/vers/ton/cache/OneDrive
# MENDELEY_RAW_DIR=/chemin/vers/mendeley/1/PBC_dataset_normal_DIB
# ACEVEDO_DATA_DIR=/chemin/vers/datasets/Acevedo/Acevedo
# DEMO_IMAGES_DIR=/chemin/vers/un/dossier/de/demo (optionnel, défaut: data/Source_100)
